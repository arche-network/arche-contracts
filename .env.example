# Copy this file to .env and fill in your values
# Never commit .env

# === Deployment Wallet (fresh throwaway wallet, NOT your main) ===
PRIVATE_KEY=0x_YOUR_FRESH_PRIVATE_KEY_HERE

# === RPC Endpoints ===
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arche Testnet (from Conduit dashboard after chain launches)
ARCHE_TESTNET_RPC_URL=https://arche-testnet.conduit.xyz/rpc

# === Verification ===
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# === Deployed Addresses (fill after first deployment) ===
ARCHE_TREASURY=
ARCHE_REGISTRY=
ARCHE_TAX=
ARCHE_SERVICE_PAYMENT=
ARCHE_REVENUE_SHARE=
